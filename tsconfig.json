{
  "compilerOptions": {
    "target": "ES2015",
    "module": "NodeNext",
    "sourceMap": true,
    "moduleResolution": "NodeNext",
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "jsx": "react",
    "lib": ["dom", "dom.iterable", "esnext"],
    // "no-debugger": false,
    // "baseUrl": ".",
    "paths": {
      "src/*": ["./src/scripts/*"]
    }
    // "outDir": "./compiled-assets/"
  },
  "files": ["src/scripts/scripts.ts"],
  "typeRoots": ["src/scripts/@types/**/*"],
  "include": ["src/scripts"]
}
